{
  "name": "mooncake-bot",
  "version": "1.0.0",
  "description": "A GitHub App bot for the Mooncake project - auto-greets, labels, and manages issues/PRs",
  "author": "kvcache-ai",
  "license": "MIT",
  "homepage": "https://github.com/kvcache-ai/Mooncake",
  "keywords": [
    "probot",
    "github",
    "probot-app",
    "mooncake"
  ],
  "scripts": {
    "build": "tsc",
    "start": "probot run ./lib/index.js",
    "dev": "nodemon --exec \"npm run build && npm start\""
  },
  "dependencies": {
    "probot": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
